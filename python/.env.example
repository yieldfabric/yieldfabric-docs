# YieldFabric Python CLI configuration.
# Copy to `.env` (which is gitignored) and fill in. The CLI auto-loads
# ./.env at startup; real shell env vars take precedence over the file.

# --- Service URLs ---------------------------------------------------------
# Point these at the environment you're deploying assets into.
AUTH_SERVICE_URL=https://auth.yieldfabric.com
PAY_SERVICE_URL=https://pay.test.yieldfabric.com

# --- Authentication -------------------------------------------------------
# Preferred: a backend-service API key. The CLI exchanges this for a
# short-lived JWT at boot (POST /auth/api-key). Issue one once with a
# one-time user JWT:
#   curl -X POST "$AUTH_SERVICE_URL/auth/api-key/generate" \
#        -H "Authorization: Bearer <one-time user JWT>" \
#        -H "Content-Type: application/json" \
#        -d '{"service_name":"asset-setup","description":"setup CLI"}'
# Store the returned `yf_api_…` value here. Revocable, auditable, no
# plaintext passwords on disk. The key owner needs SuperAdmin/Admin so
# the create-token/asset/fiat mutations are permitted.
API_KEY=yf_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fallback: if API_KEY is unset, `setup` logs in the FIRST user declared
# in setup.yaml (conventionally a SuperAdmin) with email/password.

# --- Optional -------------------------------------------------------------
# DEBUG=true
# COMMAND_DELAY=0
# REQUEST_TIMEOUT=30
